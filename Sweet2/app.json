{
  "expo": {
    "name": "Sweet",
    "slug": "Sweet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_sweet.png",
    "scheme": "sweet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C19A6B",
        "foregroundImage": "./assets/images/icon_sweet.png"
      },
      "edgeToEdgeEnabled": true
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon_sweet.png",
          "resizeMode": "contain",
          "backgroundColor": "#EAD8C0"
        }
      ]
    ]
  }
}